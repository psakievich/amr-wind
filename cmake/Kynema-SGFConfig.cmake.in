@PACKAGE_INIT@

list(APPEND CMAKE_MODULE_PATH "${PACKAGE_PREFIX_DIR}/@CMAKE_INSTALL_DATADIR@/cmake/Modules")

set(KYNEMA_SGF_ENABLE_W2A @KYNEMA_SGF_ENABLE_W2A@)
set(KYNEMA_SGF_ENABLE_MASA @KYNEMA_SGF_ENABLE_MASA@)
set(KYNEMA_SGF_ENABLE_NETCDF @KYNEMA_SGF_ENABLE_NETCDF@)

include(CMakeFindDependencyMacro)

find_dependency(AMReX)
find_dependency(AMReX-Hydro)

if (KYNEMA_SGF_ENABLE_W2A)
  find_dependency(Waves2AMR)
endif()

if (KYNEMA_SGF_ENABLE_MASA)
  find_dependency(MASA)
endif()

if (KYNEMA_SGF_ENABLE_NETCDF)
  find_dependency(NetCDF)
endif()

set(KYNEMA_SGF_INCLUDE_DIRS "${PACKAGE_PREFIX_DIR}/@CMAKE_INSTALL_INCLUDEDIR@")
set(KYNEMA_SGF_LIBRARY_DIRS "${PACKAGE_PREFIX_DIR}/@CMAKE_INSTALL_LIBDIR@")

include("${CMAKE_CURRENT_LIST_DIR}/@PROJECT_NAME@Targets.cmake")

set(KYNEMA_SGF_LIBRARIES "@PROJECT_NAME@::@aw_api_lib@")

set(KYNEMA_SGF_FOUND TRUE)

check_required_components(KYNEMA_SGF)
