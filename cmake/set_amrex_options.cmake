#Set amrex options
set(USE_XSDK_DEFAULTS OFF)
set(AMReX_SPACEDIM 3)
set(AMReX_AMRDATA OFF)
set(AMReX_AMRLEVEL OFF)
set(AMReX_ASSERTIONS OFF)
set(AMReX_ASCENT ${KYNEMA_SGF_ENABLE_ASCENT})
set(AMReX_BACKTRACE OFF)
set(AMReX_BASE_PROFILE OFF)
set(AMReX_COMM_PROFILE OFF)
set(AMReX_CONDUIT ${KYNEMA_SGF_ENABLE_ASCENT})
set(AMReX_PRECISION "${KYNEMA_SGF_PRECISION}" CACHE STRING "Floating point precision" FORCE)
set(AMReX_EB OFF)
set(AMReX_FORTRAN OFF)
set(AMReX_FORTRAN_INTERFACES OFF)
set(AMReX_FPE OFF)
set(AMReX_GPU_RDC ${KYNEMA_SGF_ENABLE_CUDA_RDC})
set(AMReX_HYPRE ${KYNEMA_SGF_ENABLE_HYPRE})
set(AMReX_LINEAR_SOLVERS ON)
set(AMReX_MEM_PROFILE OFF)
set(AMReX_MPI ${KYNEMA_SGF_ENABLE_MPI})
set(AMReX_OMP ${KYNEMA_SGF_ENABLE_OPENMP})
set(AMReX_PARTICLES ON)
set(AMReX_PIC ON)
set(AMReX_PLOTFILE_TOOLS ${KYNEMA_SGF_ENABLE_FCOMPARE})
set(AMReX_PROFPARSER OFF)
set(AMReX_SENSEI OFF)
set(AMReX_SUNDIALS OFF)
set(AMReX_TINY_PROFILE ${KYNEMA_SGF_ENABLE_TINY_PROFILE})
set(AMReX_TRACE_PROFILE OFF)
set(AMReX_HDF5 ${KYNEMA_SGF_ENABLE_HDF5})
set(AMReX_HDF5_ZFP ${KYNEMA_SGF_ENABLE_HDF5_ZFP})
set(AMReX_FFT ${KYNEMA_SGF_ENABLE_FFT})
set(AMReX_BUILD_SHARED_LIBS ${BUILD_SHARED_LIBS})

if (KYNEMA_SGF_ENABLE_CUDA)
  set(AMReX_GPU_BACKEND CUDA CACHE STRING "AMReX GPU type" FORCE)
elseif(KYNEMA_SGF_ENABLE_ROCM)
  set(AMReX_GPU_BACKEND HIP CACHE STRING "AMReX GPU type" FORCE)
elseif(KYNEMA_SGF_ENABLE_SYCL)
  set(AMReX_GPU_BACKEND SYCL CACHE STRING "AMReX GPU type" FORCE)
else()
  set(AMReX_GPU_BACKEND NONE CACHE STRING "AMReX GPU type" FORCE)
endif()
